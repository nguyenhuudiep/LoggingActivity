@model PartnerActionLimitSettingsViewModel

@{
    ViewData["Title"] = "Hạn mức user-action";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";

    var filter = Model.Filter;
    var selectedUserKeyType = string.IsNullOrWhiteSpace(Model.UpsertRequest.UserKeyType)
        ? ActorIdentifierTypes.UserId
        : ActorIdentityHelper.NormalizeType(Model.UpsertRequest.UserKeyType, null);

    var currentPage = Model.Rules.Page;
    var totalPages = Model.Rules.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Rules.Page - 1) * Model.Rules.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildPageUrl(int page)
    {
        var query = new Dictionary<string, string?>();

        if (!string.IsNullOrWhiteSpace(filter.PartnerId))
        {
            query["partnerId"] = filter.PartnerId;
        }

        if (!string.IsNullOrWhiteSpace(filter.UserId))
        {
            query["userId"] = filter.UserId;
        }

        if (!string.IsNullOrWhiteSpace(filter.UserKeyType))
        {
            query["userKeyType"] = filter.UserKeyType;
        }

        if (!string.IsNullOrWhiteSpace(filter.Action))
        {
            query["action"] = filter.Action;
        }

        if (filter.IsActive.HasValue)
        {
            query["isActive"] = filter.IsActive.Value.ToString().ToLowerInvariant();
        }

        query["page"] = page.ToString();
        query["pageSize"] = filter.PageSize.ToString();

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(Url.Action("Index")!, query);
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Partner configuration</span>
        <h1 class="page-title">Cấu hình hạn mức theo user và action</h1>
        <p class="page-subtitle">Thiết lập số lượt tối đa theo ngày cho từng user-action trong từng partner mà không tác động luồng nhận log.</p>
    </div>
    <div class="page-toolbar">
        <button
            type="button"
            class="btn btn-dark"
            data-limit-create-trigger
            data-bs-toggle="modal"
            data-bs-target="#partnerActionLimitModal">
            Thêm cấu hình
        </button>
    </div>
</section>

<div class="alert alert-info mb-4" role="alert">
    <strong>Nguyên tắc hạn mức:</strong> hạn mức được tính theo ngày và tự reset lúc <strong>00:00 (GMT+7)</strong>.
    API nhận log <strong>POST /api/partner/activity</strong> không chặn theo hạn mức; hệ thống cung cấp API check riêng để đối tác tự kiểm tra trước khi gửi log.
</div>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@filter.PageSize" />

            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="filterPartnerId">Partner</label>
                <select id="filterPartnerId" name="partnerId" class="form-select" data-enhanced-select data-placeholder="Tất cả partner">
                    <option value="">Tất cả partner</option>
                    @foreach (var partner in Model.PartnerOptions)
                    {
                        <option value="@partner.Id" selected="@(string.Equals(partner.Id, filter.PartnerId, StringComparison.OrdinalIgnoreCase))">@partner.Name</option>
                    }
                </select>
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="filterUserId">UserId</label>
                <input id="filterUserId" name="userId" class="form-control" value="@filter.UserId" placeholder="Tìm user" />
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="filterUserKeyType">User key type</label>
                <select id="filterUserKeyType" name="userKeyType" class="form-select" data-enhanced-select data-placeholder="Tất cả loại key">
                    <option value="">Tất cả loại key</option>
                    @foreach (var option in Model.UserKeyTypeOptions)
                    {
                        <option value="@option.Value" selected="@(string.Equals(option.Value, filter.UserKeyType, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                    }
                </select>
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="filterAction">Action</label>
                <select id="filterAction" name="action" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả action</option>
                    @foreach (var option in Model.ActionOptions)
                    {
                        <option value="@option.Value" selected="@(string.Equals(option.Value, filter.Action, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                    }
                </select>
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="filterIsActive">Trạng thái</label>
                <select id="filterIsActive" name="isActive" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả">
                    <option value="" selected="@(!filter.IsActive.HasValue)">Tất cả</option>
                    <option value="true" selected="@(filter.IsActive == true)">Active</option>
                    <option value="false" selected="@(filter.IsActive == false)">Inactive</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <button class="btn btn-dark" type="submit">Lọc dữ liệu</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Xóa bộ lọc</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách cấu hình hạn mức</h2>
            <p class="data-card__subtitle">Hiển thị @Model.Rules.TotalCount cấu hình theo bộ lọc hiện tại.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Partner</th>
                    <th>UserId</th>
                    <th>Key type</th>
                    <th>Action</th>
                    <th>Daily limit</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Model.Rules.Items)
                {
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td class="fw-semibold">@rule.PartnerName</td>
                        <td>@rule.ActorIdentifier</td>
                        <td>@rule.ActorIdentifierType</td>
                        <td>@rule.Action</td>
                        <td>@rule.DailyLimit</td>
                        <td>
                            @if (rule.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="table-actions justify-content-end">
                                <button
                                    type="button"
                                    class="btn btn-sm btn-outline-dark"
                                    data-limit-edit-trigger
                                    data-bs-toggle="modal"
                                    data-bs-target="#partnerActionLimitModal"
                                    data-partner-id="@rule.PartnerId"
                                    data-user-id="@rule.ActorIdentifier"
                                    data-user-key-type="@rule.ActorIdentifierType"
                                    data-action="@rule.Action"
                                    data-daily-limit="@rule.DailyLimit"
                                    data-is-active="@(rule.IsActive.ToString().ToLowerInvariant())">
                                    Sửa
                                </button>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="PartnerId" value="@rule.PartnerId" />
                                    <input type="hidden" name="UserId" value="@rule.ActorIdentifier" />
                                    <input type="hidden" name="Action" value="@rule.Action" />

                                    <input type="hidden" name="filterPartnerId" value="@filter.PartnerId" />
                                    <input type="hidden" name="filterUserId" value="@filter.UserId" />
                                    <input type="hidden" name="filterUserKeyType" value="@filter.UserKeyType" />
                                    <input type="hidden" name="filterAction" value="@filter.Action" />
                                    <input type="hidden" name="filterIsActive" value="@filter.IsActive" />
                                    <input type="hidden" name="filterPage" value="@filter.Page" />
                                    <input type="hidden" name="filterPageSize" value="@filter.PageSize" />

                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Rules.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-secondary py-4">Không có cấu hình nào khớp bộ lọc hiện tại.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Rules.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Rules.Page / @Model.Rules.TotalPages - Tổng @Model.Rules.TotalCount bản ghi</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="partnerId" value="@filter.PartnerId" />
                    <input type="hidden" name="userId" value="@filter.UserId" />
                    <input type="hidden" name="userKeyType" value="@filter.UserKeyType" />
                    <input type="hidden" name="action" value="@filter.Action" />
                    <input type="hidden" name="isActive" value="@filter.IsActive" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="limitPageSize">Hiển thị</label>
                    <select id="limitPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="partnerActionLimitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <div>
                    <div class="danger-modal__eyebrow">Partner configuration</div>
                    <h5 class="modal-title fw-bold mb-0" data-limit-modal-title>Thêm cấu hình hạn mức</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <form asp-action="Upsert" method="post" data-limit-upsert-form>
                @Html.AntiForgeryToken()

                <input type="hidden" name="filterPartnerId" value="@filter.PartnerId" />
                <input type="hidden" name="filterUserId" value="@filter.UserId" />
                <input type="hidden" name="filterUserKeyType" value="@filter.UserKeyType" />
                <input type="hidden" name="filterAction" value="@filter.Action" />
                <input type="hidden" name="filterIsActive" value="@filter.IsActive" />
                <input type="hidden" name="filterPage" value="@filter.Page" />
                <input type="hidden" name="filterPageSize" value="@filter.PageSize" />

                <div class="modal-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                    }

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="modalPartnerId">Partner</label>
                            <select id="modalPartnerId" name="PartnerId" class="form-select" data-enhanced-select data-placeholder="Chọn partner" required>
                                <option value=""></option>
                                @foreach (var partner in Model.PartnerOptions)
                                {
                                    <option value="@partner.Id" selected="@(string.Equals(partner.Id, Model.UpsertRequest.PartnerId, StringComparison.OrdinalIgnoreCase))">@partner.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="modalUserId">UserId</label>
                            <input id="modalUserId" name="UserId" class="form-control" value="@Model.UpsertRequest.UserId" required />
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label" for="modalUserKeyType">User key type</label>
                            <select id="modalUserKeyType" name="UserKeyType" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Chọn loại key">
                                @foreach (var option in Model.UserKeyTypeOptions)
                                {
                                    <option value="@option.Value" selected="@(string.Equals(option.Value, selectedUserKeyType, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label" for="modalAction">Action</label>
                            <select id="modalAction" name="Action" class="form-select" data-enhanced-select data-placeholder="Chọn action" required>
                                <option value=""></option>
                                @foreach (var option in Model.ActionOptions)
                                {
                                    <option value="@option.Value" selected="@(string.Equals(option.Value, Model.UpsertRequest.Action, StringComparison.OrdinalIgnoreCase))">@option.Label</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label" for="modalDailyLimit">Daily limit</label>
                            <input id="modalDailyLimit" name="DailyLimit" type="number" min="1" max="1000000" class="form-control" value="@(Model.UpsertRequest.DailyLimit > 0 ? Model.UpsertRequest.DailyLimit : 1)" required />
                            <div class="form-text">Số lượt tối đa trong 1 ngày, reset vào 00:00 (GMT+7).</div>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="modalIsActive" name="IsActive" value="true" checked="@(Model.UpsertRequest.IsActive)" />
                                <input type="hidden" name="IsActive" value="false" />
                                <label class="form-check-label" for="modalIsActive">Kích hoạt rule</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded p-3 bg-light-subtle">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <div>
                                        <div class="fw-semibold">Xem nhanh API check hạn mức</div>
                                        <div class="text-secondary small">Nội dung mẫu được sinh theo dữ liệu hiện tại trong modal.</div>
                                    </div>
                                </div>

                                <div class="small text-secondary mb-1">GET /api/partner/action-limit/check (dùng X-Api-Key header)</div>
                                <pre class="api-block mb-2"><code data-limit-curl-get></code></pre>
                                <button type="button" class="btn btn-sm btn-outline-dark mb-3" data-copy-target="get">Copy lệnh GET</button>

                                <div class="small text-secondary mb-1">POST /api/partner/action-limit/check-by-key (dùng partnerApiKey trong body)</div>
                                <pre class="api-block mb-2"><code data-limit-curl-post></code></pre>
                                <button type="button" class="btn btn-sm btn-outline-dark" data-copy-target="post">Copy lệnh POST</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-dark" data-limit-modal-submit>Lưu cấu hình</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modalElement = document.getElementById("partnerActionLimitModal");
            if (!modalElement || typeof window.bootstrap === "undefined") {
                return;
            }

            var modal = new window.bootstrap.Modal(modalElement);
            var modalTitle = modalElement.querySelector("[data-limit-modal-title]");
            var modalSubmit = modalElement.querySelector("[data-limit-modal-submit]");

            var partnerInput = modalElement.querySelector("[name='PartnerId']");
            var userIdInput = modalElement.querySelector("[name='UserId']");
            var userKeyTypeInput = modalElement.querySelector("[name='UserKeyType']");
            var actionInput = modalElement.querySelector("[name='Action']");
            var dailyLimitInput = modalElement.querySelector("[name='DailyLimit']");
            var isActiveInput = modalElement.querySelector("[name='IsActive'][type='checkbox']");
            var curlGetCode = modalElement.querySelector("[data-limit-curl-get]");
            var curlPostCode = modalElement.querySelector("[data-limit-curl-post]");

            function escapeJsonValue(value) {
                return (value || "")
                    .replace(/\\/g, "\\\\")
                    .replace(/\"/g, "\\\"");
            }

            function buildGetCurl() {
                var userId = encodeURIComponent(userIdInput.value || "");
                var userKeyType = encodeURIComponent(userKeyTypeInput.value || "");
                var action = encodeURIComponent(actionInput.value || "");

                return "curl -X GET \"@baseUrl/api/partner/action-limit/check?userId=" + userId
                    + "&userKeyType=" + userKeyType
                    + "&action=" + action
                    + "\" \\\n+  -H \"X-Api-Key: YOUR_PARTNER_API_KEY\"";
            }

            function buildPostCurl() {
                var userId = escapeJsonValue(userIdInput.value || "");
                var userKeyType = escapeJsonValue(userKeyTypeInput.value || "");
                var action = escapeJsonValue(actionInput.value || "");

                return "curl -X POST \"@baseUrl/api/partner/action-limit/check-by-key\" \\\n+  -H \"Content-Type: application/json\" \\\n+  -d '{\n"
                    + "    \"partnerApiKey\": \"YOUR_PARTNER_API_KEY\",\n"
                    + "    \"userId\": \"" + userId + "\",\n"
                    + "    \"userKeyType\": \"" + userKeyType + "\",\n"
                    + "    \"action\": \"" + action + "\"\n"
                    + "  }'";
            }

            function refreshApiPreview() {
                if (curlGetCode) {
                    curlGetCode.textContent = buildGetCurl();
                }

                if (curlPostCode) {
                    curlPostCode.textContent = buildPostCurl();
                }
            }

            function copyTextToClipboard(text) {
                if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
                    return navigator.clipboard.writeText(text);
                }

                return new Promise(function (resolve, reject) {
                    try {
                        var textArea = document.createElement("textarea");
                        textArea.value = text;
                        textArea.style.position = "fixed";
                        textArea.style.opacity = "0";
                        document.body.appendChild(textArea);
                        textArea.focus();
                        textArea.select();
                        document.execCommand("copy");
                        document.body.removeChild(textArea);
                        resolve();
                    }
                    catch (error) {
                        reject(error);
                    }
                });
            }

            function setSelectValue(element, value) {
                if (!element) {
                    return;
                }

                var normalizedValue = value || "";
                if (typeof window.jQuery !== "undefined" && window.jQuery(element).hasClass("select2-hidden-accessible")) {
                    window.jQuery(element).val(normalizedValue).trigger("change");
                    return;
                }

                element.value = normalizedValue;
            }

            function openCreateModal() {
                modalTitle.textContent = "Thêm cấu hình hạn mức";
                modalSubmit.textContent = "Lưu cấu hình";

                setSelectValue(partnerInput, "@Model.UpsertRequest.PartnerId");
                userIdInput.value = "";
                setSelectValue(userKeyTypeInput, "@ActorIdentifierTypes.UserId");
                setSelectValue(actionInput, "");
                dailyLimitInput.value = "1";
                isActiveInput.checked = true;
                refreshApiPreview();
            }

            [partnerInput, userIdInput, userKeyTypeInput, actionInput].forEach(function (element) {
                if (!element) {
                    return;
                }

                element.addEventListener("change", refreshApiPreview);
                element.addEventListener("input", refreshApiPreview);
            });

            modalElement.querySelectorAll("[data-copy-target]").forEach(function (button) {
                button.addEventListener("click", function () {
                    var target = button.getAttribute("data-copy-target");
                    var text = target === "post"
                        ? (curlPostCode ? curlPostCode.textContent : "")
                        : (curlGetCode ? curlGetCode.textContent : "");

                    var originalLabel = button.textContent;
                    copyTextToClipboard(text || "")
                        .then(function () {
                            button.textContent = "Đã copy";
                            setTimeout(function () { button.textContent = originalLabel; }, 1200);
                        })
                        .catch(function () {
                            button.textContent = "Copy lỗi";
                            setTimeout(function () { button.textContent = originalLabel; }, 1200);
                        });
                });
            });

            document.querySelectorAll("[data-limit-create-trigger]").forEach(function (button) {
                button.addEventListener("click", function () {
                    openCreateModal();
                });
            });

            document.querySelectorAll("[data-limit-edit-trigger]").forEach(function (button) {
                button.addEventListener("click", function () {
                    modalTitle.textContent = "Sửa cấu hình hạn mức";
                    modalSubmit.textContent = "Cập nhật";

                    setSelectValue(partnerInput, button.getAttribute("data-partner-id") || "");
                    userIdInput.value = button.getAttribute("data-user-id") || "";
                    setSelectValue(userKeyTypeInput, button.getAttribute("data-user-key-type") || "@ActorIdentifierTypes.UserId");
                    setSelectValue(actionInput, button.getAttribute("data-action") || "");
                    dailyLimitInput.value = button.getAttribute("data-daily-limit") || "1";
                    isActiveInput.checked = (button.getAttribute("data-is-active") || "false") === "true";
                    refreshApiPreview();
                });
            });

            refreshApiPreview();

            @if (!ViewData.ModelState.IsValid)
            {
                <text>modal.show();</text>
            }
        })();
    </script>
}
