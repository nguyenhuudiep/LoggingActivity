@model PartnerEditViewModel

@{
    ViewData["Title"] = "Cập nhật partner";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <section class="page-hero">
            <div class="page-hero__content">
                <span class="page-eyebrow">Partner maintenance</span>
                <h1 class="page-title">Cập nhật partner</h1>
                <p class="page-subtitle">Điều chỉnh tên partner, trạng thái hoạt động và theo dõi API key của đối tác tích hợp.</p>
            </div>
            <div class="page-toolbar">
                <a class="btn btn-outline-dark" asp-action="Index">Quay lại</a>
            </div>
        </section>

        <div class="card border-0 shadow-sm form-shell">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check mb-3">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.ApiKey))
                            {
                                <label class="form-label">API key hiện tại</label>
                                <div class="readonly-block"><code>@Model.ApiKey</code></div>
                            }
                        </div>
                    </div>
                    <div class="form-shell__footer">
                        <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
                        <button type="submit" class="btn btn-dark">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}