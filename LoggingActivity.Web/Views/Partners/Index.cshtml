@model PartnerListViewModel

@{
    ViewData["Title"] = "Cấu hình partner";
    var currentPage = Model.Partners.Page;
    var totalPages = Model.Partners.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Partners.Page - 1) * Model.Partners.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildPageUrl(int page)
    {
        return Url.Action("Index", new
        {
            page,
            pageSize = Model.Filter.PageSize
        })!;
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Partner configuration</span>
        <h1 class="page-title">Quản lý partner gửi log</h1>
        <p class="page-subtitle">Mỗi partner có API key riêng để gọi endpoint tạo log. Bạn chỉ cần quản lý theo tên partner và trạng thái hoạt động.</p>
    </div>
    <div class="page-toolbar">
        <a class="btn btn-dark" asp-action="Create">Tạo partner</a>
        <a class="btn btn-outline-secondary" asp-action="Export">Export CSV</a>
    </div>
</section>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách partner</h2>
            <p class="data-card__subtitle">Quản lý tên đối tác tích hợp, trạng thái hoạt động và API key dùng để gửi log.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Tên partner</th>
                    <th>Trạng thái</th>
                    <th>API key</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var partner in Model.Partners.Items)
                {
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td class="fw-semibold">@partner.Name</td>
                        <td>
                            @if (partner.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">Inactive</span>
                            }
                        </td>
                        <td><code class="key-pill">@partner.ApiKey</code></td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@partner.Id">Sửa</a>
                                <form asp-action="RegenerateApiKey" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="partnerId" value="@partner.Id" />
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Tạo lại key</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Partners.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-4">Chưa có partner nào được cấu hình.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Partners.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Partners.Page / @Model.Partners.TotalPages - Tổng @Model.Partners.TotalCount bản ghi</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="partnersFooterPageSize">Hiển thị</label>
                    <select id="partnersFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>