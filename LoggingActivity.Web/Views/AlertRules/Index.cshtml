@model AlertRuleManagementViewModel

@{
    ViewData["Title"] = "Cấu hình cảnh báo";
    var currentPage = Model.Rules.Page;
    var totalPages = Model.Rules.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Rules.Page - 1) * Model.Rules.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildDangerModalId(string prefix, string? value)
    {
        var safeValue = System.Text.RegularExpressions.Regex.Replace(value ?? string.Empty, "[^a-zA-Z0-9_-]", "-");
        return $"{prefix}-{safeValue}";
    }

    string BuildPageUrl(int page)
    {
        return Url.Action("Index", new
        {
            searchTerm = Model.Filter.SearchTerm,
            actionCode = Model.Filter.ActionCode,
            isActive = Model.Filter.IsActive,
            page,
            pageSize = Model.Filter.PageSize
        })!;
    }

    string BuildEditUrl(string? action)
    {
        return Url.Action("Index", new
        {
            searchTerm = Model.Filter.SearchTerm,
            actionCode = Model.Filter.ActionCode,
            isActive = Model.Filter.IsActive,
            page = Model.Filter.Page,
            pageSize = Model.Filter.PageSize,
            editAction = action
        })!;
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Configuration</span>
        <h1 class="page-title">Cấu hình cảnh báo</h1>
        <p class="page-subtitle">Thiết lập ngưỡng số log tối đa theo ngày cho từng action đã được định nghĩa trong hệ thống.</p>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form asp-action="Save" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <input asp-for="Input.ExistingAction" type="hidden" />
            <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
            <input type="hidden" name="actionCode" value="@Model.Filter.ActionCode" />
            <input type="hidden" name="isActive" value="@Model.Filter.IsActive?.ToString()?.ToLowerInvariant()" />
            <input type="hidden" name="page" value="@Model.Filter.Page" />
            <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="Input.Action" class="form-label">Action</label>
                <select asp-for="Input.Action" class="form-select" data-enhanced-select data-placeholder="Chọn action cảnh báo">
                    <option value="">Chọn action</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code">@action.DisplayName (@action.Code)</option>
                    }
                </select>
                <span asp-validation-for="Input.Action" class="text-danger"></span>
            </div>
            <div class="col-lg-3 col-md-6">
                <label asp-for="Input.DailyLimit" class="form-label">Ngưỡng tối đa/ngày</label>
                <input asp-for="Input.DailyLimit" class="form-control" type="number" min="1" />
                <span asp-validation-for="Input.DailyLimit" class="text-danger"></span>
            </div>
            <div class="col-lg-2 col-md-6">
                <div class="form-check form-switch mt-4 pt-2">
                    <input asp-for="Input.IsActive" class="form-check-input" />
                    <label asp-for="Input.IsActive" class="form-check-label">Đang bật</label>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 d-flex justify-content-lg-end gap-2">
                @if (!string.IsNullOrWhiteSpace(Model.Input.ExistingAction))
                {
                    <a class="btn btn-outline-secondary" href="@BuildEditUrl(null)">Hủy</a>
                }
                <button type="submit" class="btn btn-dark">@(string.IsNullOrWhiteSpace(Model.Input.ExistingAction) ? "Lưu cấu hình" : "Cập nhật")</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
            <div class="col-lg-4 col-md-12">
                <label class="form-label" for="alertRuleSearchTerm">Từ khóa</label>
                <input id="alertRuleSearchTerm" name="searchTerm" value="@Model.Filter.SearchTerm" class="form-control" placeholder="Action cảnh báo" />
            </div>
            <div class="col-lg-3 col-md-4">
                <label class="form-label" for="alertRuleActionCode">Action</label>
                <select id="alertRuleActionCode" name="actionCode" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code" selected="@(action.Code == Model.Filter.ActionCode)">@action.DisplayName (@action.Code)</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-4">
                <label class="form-label" for="alertRuleIsActive">Trạng thái</label>
                <select id="alertRuleIsActive" name="isActive" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả trạng thái">
                    <option value="" selected="@(!Model.Filter.IsActive.HasValue)">Tất cả</option>
                    <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.Filter.IsActive == false)">Paused</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách rule cảnh báo</h2>
            <p class="data-card__subtitle">Mỗi rule áp dụng cho một action log đã được định nghĩa trong màn cấu hình action log.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Action</th>
                    <th>Ngưỡng/ngày</th>
                    <th>Trạng thái</th>
                    <th>Cập nhật</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Model.Rules.Items)
                {
                    var modalId = BuildDangerModalId("deleteAlertRuleModal", rule.Action);
                    var formId = BuildDangerModalId("deleteAlertRuleForm", rule.Action);
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td class="fw-semibold">@rule.Action</td>
                        <td>@rule.DailyLimit</td>
                        <td>
                            @if (rule.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Paused</span>
                            }
                        </td>
                        <td>@rule.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="table-actions justify-content-end">
                                <a class="btn btn-sm btn-outline-dark" href="@BuildEditUrl(rule.Action)">Sửa</a>
                                <form asp-action="ToggleStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="@rule.Action" />
                                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                                    <input type="hidden" name="actionCode" value="@Model.Filter.ActionCode" />
                                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive?.ToString()?.ToLowerInvariant()" />
                                    <input type="hidden" name="page" value="@Model.Filter.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">@(rule.IsActive ? "Tắt" : "Bật")</button>
                                </form>
                                <form id="@formId" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="@rule.Action" />
                                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                                    <input type="hidden" name="actionCode" value="@Model.Filter.ActionCode" />
                                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive?.ToString()?.ToLowerInvariant()" />
                                    <input type="hidden" name="page" value="@Model.Filter.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#@modalId">Xóa</button>
                                </form>
                                <partial name="_DangerConfirmModal" model='new DangerConfirmModalViewModel
                                {
                                    ModalId = modalId,
                                    LabelId = $"{modalId}Label",
                                    Title = "Xác nhận xóa rule cảnh báo",
                                    Message = $"Bạn có chắc muốn xóa rule cảnh báo cho action {rule.Action} không?",
                                    Hint = "Thao tác này sẽ xóa cấu hình ngưỡng cảnh báo của action này, nhưng không xóa dữ liệu log đã tồn tại.",
                                    ConfirmText = "Xóa rule",
                                    FormId = formId
                                }' />
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Rules.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">Chưa có cấu hình cảnh báo nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Rules.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Rules.Page / @Model.Rules.TotalPages - Tổng @Model.Rules.TotalCount cấu hình</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="actionCode" value="@Model.Filter.ActionCode" />
                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="alertRulesFooterPageSize">Hiển thị</label>
                    <select id="alertRulesFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}