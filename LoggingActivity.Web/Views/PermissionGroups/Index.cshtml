@model PermissionGroupManagementViewModel

@{
    ViewData["Title"] = "Nhóm quyền";
    var currentPage = Model.Groups.Page;
    var totalPages = Model.Groups.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Groups.Page - 1) * Model.Groups.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    const int visiblePermissionBadgeCount = 2;

    List<string> BuildPermissionLabels(PermissionGroup group)
    {
        if (group.FunctionPermissions is null || group.FunctionPermissions.Count == 0)
        {
            return new List<string> { "Chưa có quyền chức năng" };
        }

        var labels = AdminFunctionPermissions.All
            .Where(permission => group.FunctionPermissions.Contains(permission.Code, StringComparer.OrdinalIgnoreCase))
            .Select(permission => permission.DisplayName)
            .ToList();

        return labels.Count == 0 ? new List<string> { "Chưa có quyền chức năng" } : labels;
    }

    string BuildPageUrl(int page)
    {
        return Url.Action("Index", new
        {
            searchTerm = Model.Filter.SearchTerm,
            isActive = Model.Filter.IsActive,
            page,
            pageSize = Model.Filter.PageSize
        })!;
    }

    string BuildDangerModalId(string prefix, string? value)
    {
        var safeValue = System.Text.RegularExpressions.Regex.Replace(value ?? string.Empty, "[^a-zA-Z0-9_-]", "-");
        return $"{prefix}-{safeValue}";
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Authorization catalog</span>
        <h1 class="page-title">Quản lý nhóm quyền</h1>
        <p class="page-subtitle">Tập trung danh sách nhóm quyền, bộ quyền chức năng và trạng thái sử dụng theo một màn hình dễ lọc và dễ kiểm soát.</p>
    </div>
    <div class="page-toolbar">
        <a class="btn btn-dark" asp-action="Create">Tạo nhóm quyền</a>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input asp-for="Filter.PageSize" type="hidden" />
            <div class="col-lg-4 col-md-6">
                <label asp-for="Filter.SearchTerm" class="form-label">Từ khóa</label>
                <input asp-for="Filter.SearchTerm" class="form-control" placeholder="Tên nhóm quyền, mô tả" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.IsActive" class="form-label">Trạng thái</label>
                <select asp-for="Filter.IsActive" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả trạng thái">
                    <option value="">Tất cả</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                    <a class="btn btn-outline-secondary"
                       asp-action="Export"
                       asp-route-searchTerm="@Model.Filter.SearchTerm"
                       asp-route-isActive="@Model.Filter.IsActive">Export CSV</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Tổng nhóm quyền</div><div class="metric-card__value">@Model.Statistics.TotalGroups</div><div class="metric-card__meta">Số nhóm quyền trong phạm vi lọc hiện tại.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Đang hoạt động</div><div class="metric-card__value">@Model.Statistics.ActiveGroups</div><div class="metric-card__meta">Nhóm quyền đang sẵn sàng để sử dụng.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Tạm khóa</div><div class="metric-card__value">@Model.Statistics.InactiveGroups</div><div class="metric-card__meta">Nhóm quyền hiện không còn hoạt động.</div></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách nhóm quyền</h2>
            <p class="data-card__subtitle">Tổng hợp tên nhóm quyền, mô tả ngắn, quyền chức năng và trạng thái theo bộ lọc hiện tại.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Tên nhóm quyền</th>
                    <th>Mô tả</th>
                    <th>Quyền chức năng</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in Model.Groups.Items)
                {
                    var permissionLabels = BuildPermissionLabels(group);
                    var visiblePermissionLabels = permissionLabels.Take(visiblePermissionBadgeCount).ToList();
                    var hiddenPermissionCount = Math.Max(0, permissionLabels.Count - visiblePermissionLabels.Count);
                    var permissionDetail = string.Join(", ", permissionLabels);
                    var permissionTooltip = string.Join("; ", permissionLabels);
                    var deleteModalId = BuildDangerModalId("deletePermissionGroupModal", group.Id);
                    var deleteFormId = BuildDangerModalId("deletePermissionGroupForm", group.Id);
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td class="fw-semibold">@group.Name</td>
                        <td>@group.Description</td>
                        <td>
                            <div class="permission-summary" title="@permissionTooltip">
                                @foreach (var label in visiblePermissionLabels)
                                {
                                    <span class="permission-summary__badge">@label</span>
                                }
                                @if (hiddenPermissionCount > 0)
                                {
                                    <span class="permission-summary__badge permission-summary__badge--more">+@hiddenPermissionCount</span>
                                }
                            </div>
                            <div class="permission-summary__detail">@permissionDetail</div>
                        </td>
                        <td>
                            @if (group.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@group.Id">Sửa</a>
                                <form id="@deleteFormId" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@group.Id" />
                                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive?.ToString()?.ToLowerInvariant()" />
                                    <input type="hidden" name="page" value="@Model.Filter.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#@deleteModalId">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Groups.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">Không có nhóm quyền phù hợp bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Groups.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Groups.Page / @Model.Groups.TotalPages - Tổng @Model.Groups.TotalCount nhóm quyền</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="permissionGroupsFooterPageSize">Hiển thị</label>
                    <select id="permissionGroupsFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

@foreach (var group in Model.Groups.Items)
{
    var deleteModalId = BuildDangerModalId("deletePermissionGroupModal", group.Id);
    var deleteFormId = BuildDangerModalId("deletePermissionGroupForm", group.Id);
    <partial name="_DangerConfirmModal" model='new DangerConfirmModalViewModel
    {
        ModalId = deleteModalId,
        LabelId = $"{deleteModalId}Label",
        Title = "Xóa nhóm quyền",
        Message = $"Bạn có chắc muốn xóa nhóm quyền {group.Name} không?",
        Hint = "Thao tác này không thể hoàn tác.",
        ConfirmText = "Xóa nhóm quyền",
        FormId = deleteFormId
    }' />
}