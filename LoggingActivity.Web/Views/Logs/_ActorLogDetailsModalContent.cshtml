@model ActorLogDetailsViewModel

@{
    var currentPage = Model.Logs.Page;
    var totalPages = Model.Logs.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Logs.Page - 1) * Model.Logs.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    var currentAction = Model.Filter.Action?.Trim() ?? string.Empty;
    var actionOptions = Model.AvailableActions
        .Where(item => !string.IsNullOrWhiteSpace(item.Code))
        .OrderBy(item => item.DisplayName)
        .ToList();

    if (!string.IsNullOrWhiteSpace(currentAction)
        && actionOptions.All(item => !string.Equals(item.Code, currentAction, StringComparison.OrdinalIgnoreCase)))
    {
        actionOptions.Insert(0, new LogActionDefinition
        {
            Code = currentAction,
            DisplayName = currentAction
        });
    }

    string BuildDescription(ActivityLog log)
    {
        if (!string.IsNullOrWhiteSpace(log.Description))
        {
            return log.Description;
        }

        if (!string.IsNullOrWhiteSpace(log.PartnerName)
            && !string.IsNullOrWhiteSpace(log.UserName)
            && !string.IsNullOrWhiteSpace(log.Action))
        {
            return $"Partner {log.PartnerName}, username {log.UserName} thực hiện thao tác {log.Action}.";
        }

        return log.Description;
    }

    string BuildActorDetailsUrl(int page, string? actionCode)
    {
        var parameters = new List<string>
        {
            $"actorIdentifier={Uri.EscapeDataString(Model.ActorIdentifier)}",
            $"actorIdentifierType={Uri.EscapeDataString(Model.ActorIdentifierType)}",
            $"page={page}",
            $"pageSize={Model.Filter.PageSize}"
        };

        if (!string.IsNullOrWhiteSpace(Model.Filter.PartnerId))
        {
            parameters.Add($"partnerId={Uri.EscapeDataString(Model.Filter.PartnerId)}");
        }

        if (!string.IsNullOrWhiteSpace(actionCode))
        {
            parameters.Add($"action={Uri.EscapeDataString(actionCode)}");
        }

        if (Model.Filter.From.HasValue)
        {
            parameters.Add($"from={Model.Filter.From.Value:yyyy-MM-dd}");
        }

        if (Model.Filter.To.HasValue)
        {
            parameters.Add($"to={Model.Filter.To.Value:yyyy-MM-dd}");
        }

        return $"/Logs/ActorDetails?{string.Join("&", parameters)}";
    }

    string BuildPageUrl(int page) => BuildActorDetailsUrl(page, currentAction);

    string BuildActionFilterUrl(string? action) => BuildActorDetailsUrl(1, action);
}

<div class="modal-header">
    <div>
        <div class="danger-modal__eyebrow">Chi tiết theo key</div>
        <h2 class="modal-title fs-5 fw-bold mb-0">@Model.ActorLabel: @Model.ActorIdentifier</h2>
        <div class="small text-secondary actor-log-modal__meta">Tổng @Model.Logs.TotalCount bản ghi phù hợp với bộ lọc hiện tại.</div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
</div>
<div class="modal-body p-0">
    <div class="p-3 border-bottom">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="small text-secondary fw-semibold">Lọc theo action</span>
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @if (string.IsNullOrWhiteSpace(currentAction))
                    {
                        <span>Action: Tất cả</span>
                    }
                    else
                    {
                        var selectedAction = actionOptions.FirstOrDefault(item => string.Equals(item.Code, currentAction, StringComparison.OrdinalIgnoreCase));
                        <span>Action: @(selectedAction is null || string.IsNullOrWhiteSpace(selectedAction.DisplayName) ? currentAction : selectedAction.DisplayName)</span>
                    }
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a class="dropdown-item @(string.IsNullOrWhiteSpace(currentAction) ? "active" : null)"
                           data-actor-log-modal-link
                           href="@BuildActionFilterUrl(null)">
                            Tất cả
                        </a>
                    </li>
                    @foreach (var action in actionOptions)
                    {
                        var isActive = string.Equals(action.Code, currentAction, StringComparison.OrdinalIgnoreCase);
                        <li>
                            <a class="dropdown-item @(isActive ? "active" : null)"
                               data-actor-log-modal-link
                               href="@BuildActionFilterUrl(action.Code)">
                                @(string.IsNullOrWhiteSpace(action.DisplayName) ? action.Code : action.DisplayName)
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Thời gian</th>
                    <th>Partner</th>
                    <th>Username</th>
                    <th>Action</th>
                    <th>Mô tả</th>
                    <th>Endpoint</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs.Items)
                {
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td>@log.CreatedAtUtc.ToVietnamTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@(string.IsNullOrWhiteSpace(log.PartnerName) ? "N/A" : log.PartnerName)</td>
                        <td>@log.UserName</td>
                        <td><span class="badge bg-primary-subtle text-primary-emphasis">@log.Action</span></td>
                        <td>@BuildDescription(log)</td>
                        <td><code>@log.Endpoint</code></td>
                    </tr>
                }
                @if (!Model.Logs.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-4">Không có bản ghi nào cho key này trong phạm vi bộ lọc hiện tại.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal-footer justify-content-between actor-log-modal__footer">
    <div class="text-secondary small">Trang @Model.Logs.Page / @Model.Logs.TotalPages</div>
    @if (Model.Logs.TotalPages > 1)
    {
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                    <a class="page-link" data-actor-log-modal-link href="@BuildPageUrl(currentPage - 1)">Trước</a>
                </li>

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" data-actor-log-modal-link href="@BuildPageUrl(1)">1</a>
                    </li>

                    @if (startPage > 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                }

                @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                {
                    <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                        <a class="page-link" data-actor-log-modal-link href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                    </li>
                }

                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    <li class="page-item">
                        <a class="page-link" data-actor-log-modal-link href="@BuildPageUrl(totalPages)">@totalPages</a>
                    </li>
                }

                <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                    <a class="page-link" data-actor-log-modal-link href="@BuildPageUrl(currentPage + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }
    else
    {
        <span></span>
    }
</div>
