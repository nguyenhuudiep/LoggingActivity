@model LogDashboardViewModel

@{
    ViewData["Title"] = "Log và thống kê";
    var currentPage = Model.Logs.Page;
    var totalPages = Model.Logs.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Logs.Page - 1) * Model.Logs.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildDescription(ActivityLog log)
    {
        if (!string.IsNullOrWhiteSpace(log.Description))
        {
            return log.Description;
        }

        if (!string.IsNullOrWhiteSpace(log.PartnerName)
            && !string.IsNullOrWhiteSpace(log.UserName)
            && !string.IsNullOrWhiteSpace(log.Action))
        {
            return $"Partner {log.PartnerName}, username {log.UserName} thực hiện thao tác {log.Action}.";
        }

        return log.Description;
    }

    string? BuildActorDetailsUrl(ActivityLog log)
    {
        if (string.IsNullOrWhiteSpace(log.DisplayActorIdentifier))
        {
            return null;
        }

        return Url.Action("ActorDetails", new
        {
            actorIdentifier = log.DisplayActorIdentifier,
            actorIdentifierType = log.DisplayActorIdentifierType,
            partnerId = Model.Filter.PartnerId,
            action = Model.Filter.Action,
            from = Model.Filter.From?.ToString("yyyy-MM-dd"),
            to = Model.Filter.To?.ToString("yyyy-MM-dd"),
            page = 1,
            pageSize = 10
        });
    }

    string BuildPageUrl(int page)
    {
        var query = Context.Request.Query.Keys
            .ToDictionary(key => key, key => (string?)Context.Request.Query[key].ToString());
        query["page"] = page.ToString();
        query["pageSize"] = Model.Filter.PageSize.ToString();
        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(Url.Action("Index")!, query);
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Observability</span>
        <h1 class="page-title">Danh sách log và thống kê</h1>
        <p class="page-subtitle">Theo dõi activity log do hệ thống tích hợp gửi về qua API với khả năng lọc dữ liệu, xem xu hướng và phân tích top action.</p>
    </div>
</section>

<div id="logsInsightsHost"
     data-logs-insights-url="@Url.Action("Insights", new
     {
         searchTerm = Model.Filter.SearchTerm,
         partnerId = Model.Filter.PartnerId,
         action = Model.Filter.Action,
         from = Model.Filter.From?.ToString("yyyy-MM-dd"),
         to = Model.Filter.To?.ToString("yyyy-MM-dd"),
         page = Model.Filter.Page,
         pageSize = Model.Filter.PageSize
     })"
     class="mb-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 text-secondary">Đang tải thống kê và cảnh báo...</div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input asp-for="Filter.PageSize" type="hidden" />
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.SearchTerm" class="form-label">Từ khóa</label>
                <input asp-for="Filter.SearchTerm" class="form-control" placeholder="Key, user, mô tả, endpoint" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.PartnerId" class="form-label">Partner</label>
                <select asp-for="Filter.PartnerId" class="form-select" data-enhanced-select data-placeholder="Tất cả partner">
                    <option value="">Tất cả</option>
                    @foreach (var partner in Model.AvailablePartners)
                    {
                        <option value="@partner.Id">@partner.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.Action" class="form-label">Action</label>
                <select asp-for="Filter.Action" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code">@action.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.From" class="form-label">Từ ngày</label>
                <input asp-for="Filter.From" class="form-control" type="date" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" autocomplete="off" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.To" class="form-label">Đến ngày</label>
                <input asp-for="Filter.To" class="form-control" type="date" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" autocomplete="off" />
            </div>
            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                    <a class="btn btn-outline-secondary"
                       asp-action="Export"
                       asp-route-searchTerm="@Model.Filter.SearchTerm"
                       asp-route-partnerId="@Model.Filter.PartnerId"
                       asp-route-action="@Model.Filter.Action"
                       asp-route-from='@Model.Filter.From?.ToString("yyyy-MM-dd")'
                       asp-route-to='@Model.Filter.To?.ToString("yyyy-MM-dd")'>Export CSV</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Nhật ký chi tiết</h2>
            <p class="data-card__subtitle">Danh sách bản ghi đã lọc theo bộ lọc hiện tại.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 log-list-table">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Thời gian</th>
                    <th>Partner</th>
                    <th>Key</th>
                    <th>Username</th>
                    <th>Action</th>
                    <th>Mô tả</th>
                    <th>Endpoint</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs.Items)
                {
                    var actorDetailsUrl = BuildActorDetailsUrl(log);
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td>@log.CreatedAtUtc.ToVietnamTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@(string.IsNullOrWhiteSpace(log.PartnerName) ? "N/A" : log.PartnerName)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(actorDetailsUrl))
                            {
                                <a class="actor-key-trigger" data-actor-log-trigger href="@actorDetailsUrl">@log.DisplayActorIdentifier</a>
                            }
                            else
                            {
                                <span class="text-secondary">N/A</span>
                            }
                        </td>
                        <td>@log.UserName</td>
                        <td><span class="badge bg-primary-subtle text-primary-emphasis">@log.Action</span></td>
                        <td>@BuildDescription(log)</td>
                        <td><code>@log.Endpoint</code></td>
                    </tr>
                }
                @if (!Model.Logs.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-secondary py-4">Không có log phù hợp bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Logs.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Logs.Page / @Model.Logs.TotalPages - Tổng @Model.Logs.TotalCount bản ghi</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="partnerId" value="@Model.Filter.PartnerId" />
                    <input type="hidden" name="action" value="@Model.Filter.Action" />
                    <input type="hidden" name="from" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="to" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="logsPageSize">Hiển thị</label>
                    <select id="logsPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="actorLogDetailsModal" tabindex="-1" aria-labelledby="actorLogDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div data-actor-log-modal-content>
                <div class="modal-header">
                    <div>
                        <div class="danger-modal__eyebrow">Chi tiết theo key</div>
                        <h2 class="modal-title fs-5 fw-bold mb-0" id="actorLogDetailsModalLabel">Đang tải dữ liệu</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body py-5 text-center text-secondary">
                    Đang tải bản ghi theo key...
                </div>
            </div>
        </div>
    </div>
</div>
