@model LogDashboardViewModel

@{
    ViewData["Title"] = "Log và thống kê";

    string BuildDescription(ActivityLog log)
    {
        if (!string.IsNullOrWhiteSpace(log.PartnerName)
            && !string.IsNullOrWhiteSpace(log.UserName)
            && !string.IsNullOrWhiteSpace(log.Action))
        {
            return $"Partner {log.PartnerName}, username {log.UserName} thực hiện thao tác {log.Action}.";
        }

        return log.Description;
    }

    string BuildPageUrl(int page)
    {
        return Url.Action("Index", new
        {
            searchTerm = Model.Filter.SearchTerm,
            partnerId = Model.Filter.PartnerId,
            action = Model.Filter.Action,
            from = Model.Filter.From?.ToString("yyyy-MM-dd"),
            to = Model.Filter.To?.ToString("yyyy-MM-dd"),
            page
        })!;
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Observability</span>
        <h1 class="page-title">Danh sách log và thống kê</h1>
        <p class="page-subtitle">Theo dõi activity log do hệ thống tích hợp gửi về qua API với khả năng lọc dữ liệu, xem xu hướng và phân tích top action.</p>
    </div>
</section>

@if (Model.ActiveWarnings.Any())
{
    <div class="alert alert-warning dashboard-warning mb-4" role="alert">
        <div class="dashboard-warning__header">
            <strong>Cảnh báo đang hoạt động</strong>
            <span class="text-secondary">Các userId có action đã chạm hoặc vượt ngưỡng log trong ngày hiện tại.</span>
        </div>
        <div class="dashboard-warning__list">
            @foreach (var warning in Model.ActiveWarnings)
            {
                <div class="dashboard-warning__item">
                    <span class="badge bg-danger-subtle text-danger-emphasis">@warning.UserId - @warning.UserName - @warning.Action</span>
                    <span>
                        @if (warning.IsAtLimit)
                        {
                            @:UserId @warning.UserId, user @warning.UserName có @warning.CurrentCount log hôm nay cho action @warning.Action, đã chạm ngưỡng cấu hình @warning.DailyLimit.
                        }
                        else
                        {
                            @:UserId @warning.UserId, user @warning.UserName có @warning.CurrentCount log hôm nay cho action @warning.Action, vượt ngưỡng cấu hình @warning.DailyLimit thêm @warning.ExceededBy log.
                        }
                    </span>
                </div>
            }
        </div>
    </div>
}

@if (Model.UnconfiguredActionWarnings.Any())
{
    <div class="alert alert-warning dashboard-warning mb-4" role="alert">
        <div class="dashboard-warning__header">
            <strong>Phát hiện action chưa được cấu hình</strong>
            <a class="btn btn-sm btn-outline-dark" asp-controller="LogActions" asp-action="Index">Quản lý action</a>
        </div>
        <div class="dashboard-warning__list">
            @foreach (var warning in Model.UnconfiguredActionWarnings)
            {
                <div class="dashboard-warning__item">
                    <span class="badge bg-danger-subtle text-danger-emphasis">@warning.Action</span>
                    <span>Hiện có @warning.Count log dùng action này nhưng chưa được định nghĩa trong menu Action log.</span>
                </div>
            }
        </div>
    </div>
}

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form">
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.SearchTerm" class="form-label">Từ khóa</label>
                <input asp-for="Filter.SearchTerm" class="form-control" placeholder="User, mô tả, endpoint" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.PartnerId" class="form-label">Partner</label>
                <select asp-for="Filter.PartnerId" class="form-select" data-enhanced-select data-placeholder="Tất cả partner">
                    <option value="">Tất cả</option>
                    @foreach (var partner in Model.AvailablePartners)
                    {
                        <option value="@partner.Id">@partner.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.Action" class="form-label">Action</label>
                <select asp-for="Filter.Action" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code">@action.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.From" class="form-label">Từ ngày</label>
                <input asp-for="Filter.From" class="form-control" type="date" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.To" class="form-label">Đến ngày</label>
                <input asp-for="Filter.To" class="form-control" type="date" />
            </div>
            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <a class="btn btn-outline-secondary" asp-action="Index">Xóa lọc</a>
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Tổng log</div><div class="metric-card__value">@Model.Statistics.TotalLogs</div><div class="metric-card__meta">Tổng số sự kiện đã được ghi nhận.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Log hôm nay</div><div class="metric-card__value">@Model.Statistics.TodayLogs</div><div class="metric-card__meta">Giao dịch và thao tác mới trong ngày.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Log cảnh báo trong ngày</div><div class="metric-card__value">@Model.ActiveWarnings.Count</div><div class="metric-card__meta">Số user đã chạm hoặc vượt ngưỡng cảnh báo trong ngày hiện tại.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Log tích hợp</div><div class="metric-card__value">@Model.Statistics.IntegratedLogs</div><div class="metric-card__meta">Số bản ghi được gửi vào từ API tích hợp.</div></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Nhật ký chi tiết</h2>
            <p class="data-card__subtitle">Danh sách bản ghi đã lọc theo bộ lọc hiện tại.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Thời gian</th>
                    <th>Partner</th>
                    <th>User ID</th>
                    <th>Username</th>
                    <th>Action</th>
                    <th>Mô tả</th>
                    <th>Endpoint</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs.Items)
                {
                    <tr>
                        <td>@log.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@(string.IsNullOrWhiteSpace(log.PartnerName) ? "N/A" : log.PartnerName)</td>
                        <td>@(log.ExternalUserId?.ToString() ?? "N/A")</td>
                        <td>@log.UserName</td>
                        <td><span class="badge bg-primary-subtle text-primary-emphasis">@log.Action</span></td>
                        <td>@BuildDescription(log)</td>
                        <td><code>@log.Endpoint</code></td>
                    </tr>
                }
                @if (!Model.Logs.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-4">Không có log phù hợp bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Logs.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Logs.Page / @Model.Logs.TotalPages - Tổng @Model.Logs.TotalCount bản ghi</div>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.Logs.Page <= 1 ? "disabled" : null)">
                        <a class="page-link" href="@BuildPageUrl(Model.Logs.Page - 1)">Trước</a>
                    </li>
                    @for (var pageNumber = 1; pageNumber <= Model.Logs.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.Logs.Page ? "active" : null)">
                            <a class="page-link" href="@BuildPageUrl(pageNumber)">@(pageNumber)</a>
                        </li>
                    }
                    <li class="page-item @(Model.Logs.Page >= Model.Logs.TotalPages ? "disabled" : null)">
                        <a class="page-link" href="@BuildPageUrl(Model.Logs.Page + 1)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>