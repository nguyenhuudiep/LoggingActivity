@model UserEditViewModel

@{
    ViewData["Title"] = "Cập nhật tài khoản";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <section class="page-hero">
            <div class="page-hero__content">
                <span class="page-eyebrow">Account maintenance</span>
                <h1 class="page-title">Cập nhật tài khoản</h1>
                <p class="page-subtitle">Điều chỉnh phân quyền, trạng thái hoạt động và thay đổi mật khẩu khi cần cho từng tài khoản.</p>
            </div>
            <div class="page-toolbar">
                <a class="btn btn-outline-dark" asp-action="Index">Quay lại</a>
            </div>
        </section>

        <div class="card border-0 shadow-sm form-shell">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" data-user-permission-sync>
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DisplayName" class="form-label"></label>
                            <input asp-for="DisplayName" class="form-control" />
                            <span asp-validation-for="DisplayName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label"></label>
                            <select asp-for="Role" class="form-select" data-enhanced-select data-hide-search="true" asp-items="new SelectList(SystemRoles.All)"></select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Nhóm quyền cho Admin</label>
                            @if (Model.AvailablePermissionGroups.Count == 0)
                            {
                                <div class="empty-state py-4">
                                    <div class="empty-state__title">Chưa có nhóm quyền active</div>
                                    <div class="empty-state__text">Tạo nhóm quyền trước, hoặc chọn quyền chức năng bổ sung bên dưới cho tài khoản Admin.</div>
                                </div>
                            }
                            else
                            {
                                <div class="permission-grid">
                                    @foreach (var group in Model.AvailablePermissionGroups)
                                    {
                                        <label class="permission-card">
                                            <input class="form-check-input permission-card__input" type="checkbox" name="SelectedPermissionGroupIds" value="@group.Id" data-permissions="@string.Join(",", group.FunctionPermissions)" checked="@(Model.SelectedPermissionGroupIds.Contains(group.Id ?? string.Empty))" />
                                            <span class="permission-card__content">
                                                <span class="permission-card__title">@group.Name</span>
                                                <span class="permission-card__text">@(string.IsNullOrWhiteSpace(group.Description) ? $"{group.FunctionPermissions.Count} quyền chức năng" : group.Description)</span>
                                            </span>
                                        </label>
                                    }
                                </div>
                            }
                            <div class="form-text">Chỉ áp dụng khi tài khoản thuộc nhóm Admin. Các nhóm inactive sẽ không cấp quyền khi đăng nhập.</div>
                            <span asp-validation-for="SelectedPermissionGroupIds" class="text-danger d-block mt-2"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Quyền chức năng bổ sung</label>
                            <div class="permission-grid">
                                @foreach (var permission in AdminFunctionPermissions.All)
                                {
                                    <label class="permission-card">
                                        <input class="form-check-input permission-card__input" type="checkbox" name="SelectedPermissions" value="@permission.Code" checked="@(Model.SelectedPermissions.Contains(permission.Code))" />
                                        <span class="permission-card__content">
                                            <span class="permission-card__title">@permission.ShortDisplayName</span>
                                            <span class="permission-card__text">@permission.Description</span>
                                        </span>
                                    </label>
                                }
                            </div>
                            <div class="form-text">Dùng để cấp thêm quyền ngoài nhóm quyền đã chọn. Với Auditor, hệ thống bỏ qua toàn bộ phần phân quyền Admin.</div>
                            <span asp-validation-for="SelectedPermissions" class="text-danger d-block mt-2"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check mb-3">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                    <div class="form-shell__footer">
                        <a class="btn btn-outline-secondary" asp-action="Index">Hủy</a>
                        <button type="submit" class="btn btn-dark">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}