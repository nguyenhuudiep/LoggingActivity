@model UserManagementViewModel

@{
    ViewData["Title"] = "Quản lý tài khoản";
    var currentPage = Model.Users.Page;
    var totalPages = Model.Users.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Users.Page - 1) * Model.Users.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    const int visiblePermissionBadgeCount = 2;

    List<string> BuildPermissionGroupLabels(AppUser user)
    {
        if (user.PermissionGroupIds is null || user.PermissionGroupIds.Count == 0)
        {
            return new List<string> { "Không gán nhóm quyền" };
        }

        var labels = user.PermissionGroupIds
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Select(id => Model.PermissionGroupNamesById.TryGetValue(id, out var name) ? name : "Nhóm quyền không còn tồn tại")
            .ToList();

        return labels.Count == 0 ? new List<string> { "Không gán nhóm quyền" } : labels;
    }

    string? BuildSummaryDetail(IReadOnlyList<string> labels, IReadOnlyList<string> visibleLabels, int hiddenCount)
    {
        if (labels.Count == 0)
        {
            return null;
        }

        if (hiddenCount <= 0 && labels.SequenceEqual(visibleLabels))
        {
            return null;
        }

        return string.Join(", ", labels);
    }

    string BuildPageUrl(int page)
    {
        var query = Context.Request.Query.Keys
            .ToDictionary(key => key, key => (string?)Context.Request.Query[key].ToString());
        query["page"] = page.ToString();
        query["pageSize"] = Model.Filter.PageSize.ToString();
        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(Url.Action("Index")!, query);
    }

    string BuildDangerModalId(string prefix, string? value)
    {
        var safeValue = System.Text.RegularExpressions.Regex.Replace(value ?? string.Empty, "[^a-zA-Z0-9_-]", "-");
        return $"{prefix}-{safeValue}";
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Identity management</span>
        <h1 class="page-title">Quản lý tài khoản và phân quyền</h1>
        <p class="page-subtitle">Tạo tài khoản mới và phân quyền cho đội vận hành theo một giao diện gọn, rõ ràng và dễ kiểm soát.</p>
    </div>
    <div class="page-toolbar">
        <a class="btn btn-dark" asp-action="Create">Tạo tài khoản</a>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input asp-for="Filter.PageSize" type="hidden" />
            <div class="col-lg-4 col-md-6">
                <label asp-for="Filter.SearchTerm" class="form-label">Từ khóa</label>
                <input asp-for="Filter.SearchTerm" class="form-control" placeholder="Tên đăng nhập, hiển thị, email" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.Role" class="form-label">Quyền</label>
                <select asp-for="Filter.Role" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả quyền">
                    <option value="">Tất cả</option>
                    @foreach (var role in SystemRoles.All)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label asp-for="Filter.IsActive" class="form-label">Trạng thái</label>
                <select asp-for="Filter.IsActive" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả trạng thái">
                    <option value="">Tất cả</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-12">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                    <a class="btn btn-outline-secondary"
                       asp-action="Export"
                       asp-route-searchTerm="@Model.Filter.SearchTerm"
                       asp-route-role="@Model.Filter.Role"
                       asp-route-isActive="@Model.Filter.IsActive">Export CSV</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Tổng tài khoản</div><div class="metric-card__value">@Model.Statistics.TotalUsers</div><div class="metric-card__meta">Số tài khoản trong phạm vi lọc hiện tại.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Đang hoạt động</div><div class="metric-card__value">@Model.Statistics.ActiveUsers</div><div class="metric-card__meta">Tài khoản hiện có thể đăng nhập hoặc gọi API.</div></div></div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 shadow-sm metric-card h-100"><div class="card-body p-4"><div class="metric-card__label">Tạm khóa</div><div class="metric-card__value">@Model.Statistics.InactiveUsers</div><div class="metric-card__meta">Tài khoản bị tắt trong vùng dữ liệu đang xem.</div></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách tài khoản</h2>
            <p class="data-card__subtitle">Trạng thái truy cập, vai trò và thông tin hệ thống tích hợp được tổng hợp theo bộ lọc hiện tại.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 user-access-table">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Tên đăng nhập</th>
                    <th>Tên hiển thị</th>
                    <th>Email</th>
                    <th>Quyền</th>
                    <th>Nhóm quyền</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users.Items)
                {
                    var permissionGroupLabels = BuildPermissionGroupLabels(user);
                    var visiblePermissionGroupLabels = permissionGroupLabels.Take(visiblePermissionBadgeCount).ToList();
                    var hiddenPermissionGroupCount = Math.Max(0, permissionGroupLabels.Count - visiblePermissionGroupLabels.Count);
                    var permissionGroupTooltip = string.Join("; ", permissionGroupLabels);
                    var permissionGroupDetail = BuildSummaryDetail(permissionGroupLabels, visiblePermissionGroupLabels, hiddenPermissionGroupCount);
                    var deleteModalId = BuildDangerModalId("deleteUserModal", user.Id);
                    var deleteFormId = BuildDangerModalId("deleteUserForm", user.Id);
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td class="fw-semibold">@user.UserName</td>
                        <td>@user.DisplayName</td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@user.Role</span></td>
                        <td class="user-access-table__group-col">
                            <div class="permission-summary permission-summary--stacked" title="@permissionGroupTooltip">
                                @foreach (var label in visiblePermissionGroupLabels)
                                {
                                    <span class="permission-summary__badge">@label</span>
                                }
                                @if (hiddenPermissionGroupCount > 0)
                                {
                                    <span class="permission-summary__badge permission-summary__badge--more">+@hiddenPermissionGroupCount</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(permissionGroupDetail))
                            {
                                <div class="permission-summary__detail">@permissionGroupDetail</div>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@user.Id">Sửa</a>
                                <form id="@deleteFormId" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                                    <input type="hidden" name="role" value="@Model.Filter.Role" />
                                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive?.ToString()?.ToLowerInvariant()" />
                                    <input type="hidden" name="page" value="@Model.Filter.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#@deleteModalId">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Users.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-secondary py-4">Không có tài khoản phù hợp bộ lọc.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Users.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Users.Page / @Model.Users.TotalPages - Tổng @Model.Users.TotalCount tài khoản</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="role" value="@Model.Filter.Role" />
                    <input type="hidden" name="isActive" value="@Model.Filter.IsActive" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="usersFooterPageSize">Hiển thị</label>
                    <select id="usersFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

@foreach (var user in Model.Users.Items)
{
    var deleteModalId = BuildDangerModalId("deleteUserModal", user.Id);
    var deleteFormId = BuildDangerModalId("deleteUserForm", user.Id);
    <partial name="_DangerConfirmModal" model='new DangerConfirmModalViewModel
    {
        ModalId = deleteModalId,
        LabelId = $"{deleteModalId}Label",
        Title = "Xác nhận xóa tài khoản",
        Message = $"Bạn có chắc muốn xóa tài khoản {user.UserName} không?",
        Hint = "Thao tác này sẽ xóa tài khoản khỏi hệ thống. Không thể tự xóa tài khoản đang đăng nhập và cũng không thể xóa admin cuối cùng.",
        ConfirmText = "Xóa tài khoản",
        FormId = deleteFormId
    }' />
}