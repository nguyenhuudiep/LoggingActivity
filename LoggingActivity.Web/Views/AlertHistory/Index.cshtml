@model AlertHistoryListViewModel

@{
    ViewData["Title"] = "Lịch sử cảnh báo";
    var currentPage = Model.Alerts.Page;
    var totalPages = Model.Alerts.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Alerts.Page - 1) * Model.Alerts.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildPageUrl(int page)
    {
        return Url.Action("Index", new
        {
            searchTerm = Model.Filter.SearchTerm,
            partnerId = Model.Filter.PartnerId,
            action = Model.Filter.Action,
            status = Model.Filter.Status,
            from = Model.Filter.From?.ToString("yyyy-MM-dd"),
            to = Model.Filter.To?.ToString("yyyy-MM-dd"),
            page,
            pageSize = Model.Filter.PageSize
        })!;
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Monitoring</span>
        <h1 class="page-title">Lịch sử cảnh báo</h1>
        <p class="page-subtitle">Lưu lại toàn bộ cảnh báo đã phát sinh theo mốc thời gian, có thể lọc theo khoảng ngày và xem rõ user, partner, action liên quan.</p>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
            <div class="col-lg-3 col-md-6">
                <label class="form-label" for="alertHistorySearchTerm">User</label>
                <input id="alertHistorySearchTerm" name="searchTerm" value="@Model.Filter.SearchTerm" class="form-control" placeholder="User ID hoặc username" />
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label" for="alertHistoryPartnerId">Partner</label>
                <select id="alertHistoryPartnerId" name="partnerId" class="form-select" data-enhanced-select data-placeholder="Tất cả partner">
                    <option value="">Tất cả</option>
                    @foreach (var partner in Model.AvailablePartners)
                    {
                        <option value="@partner.Id" selected="@(partner.Id == Model.Filter.PartnerId)">@partner.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryAction">Action</label>
                <select id="alertHistoryAction" name="action" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code" selected="@(action.Code == Model.Filter.Action)">@action.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryStatus">Trạng thái</label>
                <select id="alertHistoryStatus" name="status" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả trạng thái">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Filter.Status))">Tất cả</option>
                    <option value="at-limit" selected="@(Model.Filter.Status == "at-limit")">Đạt ngưỡng</option>
                    <option value="exceeded" selected="@(Model.Filter.Status == "exceeded")">Vượt ngưỡng</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryFrom">Từ ngày</label>
                <input id="alertHistoryFrom" name="from" type="date" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryTo">Đến ngày</label>
                <input id="alertHistoryTo" name="to" type="date" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-lg-12 col-md-8">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách cảnh báo đã ghi nhận</h2>
            <p class="data-card__subtitle">Mỗi dòng là một lần user chạm ngưỡng action trong ngày và đã được hệ thống lưu lịch sử cảnh báo.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 alert-history-table">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Thời điểm</th>
                    <th>Ngày cảnh báo</th>
                    <th>Partner</th>
                    <th>User ID</th>
                    <th>Username</th>
                    <th>Action</th>
                    <th>Ngưỡng</th>
                    <th>Số log</th>
                    <th>Nội dung cảnh báo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in Model.Alerts.Items)
                {
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td>@alert.OccurredAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@alert.AlertDateUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>@alert.PartnerName</td>
                        <td>@alert.UserId</td>
                        <td>@alert.UserName</td>
                        <td><span class="badge bg-danger-subtle text-danger-emphasis">@alert.Action</span></td>
                        <td>@alert.DailyLimit</td>
                        <td>@alert.CurrentCount</td>
                        <td>@alert.Message</td>
                    </tr>
                }
                @if (!Model.Alerts.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-secondary py-4">Chưa có lịch sử cảnh báo nào theo bộ lọc hiện tại.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Alerts.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Alerts.Page / @Model.Alerts.TotalPages - Tổng @Model.Alerts.TotalCount cảnh báo</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="partnerId" value="@Model.Filter.PartnerId" />
                    <input type="hidden" name="action" value="@Model.Filter.Action" />
                    <input type="hidden" name="status" value="@Model.Filter.Status" />
                    <input type="hidden" name="from" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="to" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="alertHistoryFooterPageSize">Hiển thị</label>
                    <select id="alertHistoryFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>