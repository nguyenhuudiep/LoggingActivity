@model AlertHistoryListViewModel

@{
    ViewData["Title"] = "Lịch sử cảnh báo";
    var currentPage = Model.Alerts.Page;
    var totalPages = Model.Alerts.TotalPages;
    var pageWindowSize = 5;
    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + pageWindowSize - 1);
    var rowNumber = ((Model.Alerts.Page - 1) * Model.Alerts.PageSize) + 1;

    if (endPage - startPage + 1 < pageWindowSize)
    {
        startPage = Math.Max(1, endPage - pageWindowSize + 1);
    }

    string BuildPageUrl(int page)
    {
        var query = Context.Request.Query.Keys
            .ToDictionary(key => key, key => (string?)Context.Request.Query[key].ToString());
        query["page"] = page.ToString();
        query["pageSize"] = Model.Filter.PageSize.ToString();
        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(Url.Action("Index")!, query);
    }
}

<section class="page-hero">
    <div class="page-hero__content">
        <span class="page-eyebrow">Monitoring</span>
        <h1 class="page-title">Lịch sử cảnh báo</h1>
        <p class="page-subtitle">Lưu lại toàn bộ cảnh báo đã phát sinh theo mốc thời gian, có thể lọc theo khoảng ngày và xem rõ user, partner, action liên quan.</p>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 surface-panel">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end user-filter-form user-filter-form--single-line" data-auto-submit-selects>
            <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />
            <div class="col-lg-3 col-md-6">
                <label class="form-label" for="alertHistorySearchTerm">User</label>
                <input id="alertHistorySearchTerm" name="searchTerm" value="@Model.Filter.SearchTerm" class="form-control" placeholder="Key hoặc username" />
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label" for="alertHistoryPartnerId">Partner</label>
                <select id="alertHistoryPartnerId" name="partnerId" class="form-select" data-enhanced-select data-placeholder="Tất cả partner">
                    <option value="">Tất cả</option>
                    @foreach (var partner in Model.AvailablePartners)
                    {
                        <option value="@partner.Id" selected="@(partner.Id == Model.Filter.PartnerId)">@partner.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryAction">Action</label>
                <select id="alertHistoryAction" name="action" class="form-select" data-enhanced-select data-placeholder="Tất cả action">
                    <option value="">Tất cả</option>
                    @foreach (var action in Model.AvailableActions)
                    {
                        <option value="@action.Code" selected="@(action.Code == Model.Filter.Action)">@action.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryStatus">Trạng thái</label>
                <select id="alertHistoryStatus" name="status" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="Tất cả trạng thái">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Filter.Status))">Tất cả</option>
                    <option value="at-limit" selected="@(Model.Filter.Status == "at-limit")">Đạt ngưỡng</option>
                    <option value="exceeded" selected="@(Model.Filter.Status == "exceeded")">Vượt ngưỡng</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryFrom">Từ ngày</label>
                <input id="alertHistoryFrom" name="from" type="date" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" class="form-control" autocomplete="off" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label" for="alertHistoryTo">Đến ngày</label>
                <input id="alertHistoryTo" name="to" type="date" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" class="form-control" autocomplete="off" />
            </div>
            <div class="col-lg-12 col-md-8">
                <div class="filter-actions">
                    <button type="submit" class="btn btn-dark">Lọc dữ liệu</button>
                    <a class="btn btn-outline-secondary"
                       asp-action="Export"
                       asp-route-searchTerm="@Model.Filter.SearchTerm"
                       asp-route-partnerId="@Model.Filter.PartnerId"
                       asp-route-action="@Model.Filter.Action"
                       asp-route-status="@Model.Filter.Status"
                       asp-route-from='@Model.Filter.From?.ToString("yyyy-MM-dd")'
                       asp-route-to='@Model.Filter.To?.ToString("yyyy-MM-dd")'>Export CSV</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="data-card__header">
        <div>
            <h2 class="data-card__title">Danh sách cảnh báo đã ghi nhận</h2>
            <p class="data-card__subtitle">Mỗi dòng là một lần user chạm ngưỡng action trong ngày và đã được hệ thống lưu lịch sử cảnh báo. Bấm vào Key để xem chi tiết.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 alert-history-table">
            <thead class="table-light">
                <tr>
                    <th class="table-stt-col">STT</th>
                    <th>Thời điểm</th>
                    <th>Ngày cảnh báo</th>
                    <th>Partner</th>
                    <th>Key</th>
                    <th>Username</th>
                    <th>Action</th>
                    <th>Ngưỡng</th>
                    <th>Số log</th>
                    <th>Nội dung cảnh báo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var alert in Model.Alerts.Items)
                {
                    <tr>
                        <td class="table-stt-cell">@(rowNumber++)</td>
                        <td>@alert.OccurredAtUtc.ToVietnamTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@alert.AlertDateUtc.ToVietnamTime().ToString("dd/MM/yyyy")</td>
                        <td>@alert.PartnerName</td>
                        <td>
                            <a href="#" class="alert-history-detail-trigger" 
                               data-actor-identifier="@alert.ActorIdentifier"
                               data-actor-identifier-type="@alert.ActorIdentifierType"
                               data-action="@alert.Action"
                               data-alert-date="@alert.AlertDateUtc.ToVietnamTime().ToString("yyyy-MM-dd")"
                               data-partner-id="@alert.PartnerId">
                                @alert.DisplayActorIdentifier
                            </a>
                        </td>
                        <td>@alert.UserName</td>
                        <td>
                            <a href="#" class="alert-history-detail-trigger"
                               data-actor-identifier="@alert.ActorIdentifier"
                               data-actor-identifier-type="@alert.ActorIdentifierType"
                               data-action="@alert.Action"
                               data-alert-date="@alert.AlertDateUtc.ToVietnamTime().ToString("yyyy-MM-dd")"
                               data-partner-id="@alert.PartnerId">
                                <span class="badge bg-danger-subtle text-danger-emphasis">@alert.Action</span>
                            </a>
                        </td>
                        <td>@alert.DailyLimit</td>
                        <td>@alert.CurrentCount</td>
                        <td>@alert.Message</td>
                    </tr>
                }
                @if (!Model.Alerts.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-secondary py-4">Chưa có lịch sử cảnh báo nào theo bộ lọc hiện tại.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Alerts.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <div class="text-secondary small">Trang @Model.Alerts.Page / @Model.Alerts.TotalPages - Tổng @Model.Alerts.TotalCount cảnh báo</div>
            <div class="pagination-toolbar">
                <form method="get" class="page-size-form" data-auto-submit-selects>
                    <input type="hidden" name="searchTerm" value="@Model.Filter.SearchTerm" />
                    <input type="hidden" name="partnerId" value="@Model.Filter.PartnerId" />
                    <input type="hidden" name="action" value="@Model.Filter.Action" />
                    <input type="hidden" name="status" value="@Model.Filter.Status" />
                    <input type="hidden" name="from" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="to" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="page" value="1" />

                    <label class="page-size-form__label" for="alertHistoryFooterPageSize">Hiển thị</label>
                    <select id="alertHistoryFooterPageSize" name="pageSize" class="form-select" data-enhanced-select data-hide-search="true" data-placeholder="10">
                        <option value="10" selected="@(Model.Filter.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.Filter.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                    </select>
                    <span class="page-size-form__suffix">bản ghi</span>
                </form>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage - 1)">Trước</a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(1)">1</a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == currentPage ? "active" : null)">
                                <a class="page-link" href="@BuildPageUrl(pageNumber)">@pageNumber</a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(totalPages)">@totalPages</a>
                            </li>
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : null)">
                            <a class="page-link" href="@BuildPageUrl(currentPage + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="alertHistoryDetailsModal" tabindex="-1" role="dialog" aria-labelledby="alertHistoryDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content" id="alertHistoryDetailsHost">
            <div class="modal-header">
                <div>
                    <div class="danger-modal__eyebrow">Chi tiết cảnh báo</div>
                    <h2 class="modal-title fs-5 fw-bold mb-0" id="alertHistoryDetailsModalLabel">Đang tải dữ liệu</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body py-5 text-center text-secondary">
                Đang tải bản ghi cảnh báo...
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modal = null;
            var detailsRequestVersion = 0;
            var detailsRequestAbortController = null;

            var loadingMarkup = [
                '<div class="modal-header">',
                '  <div>',
                '    <div class="danger-modal__eyebrow">Chi tiết cảnh báo</div>',
                '    <h2 class="modal-title fs-5 fw-bold mb-0" id="alertHistoryDetailsModalLabel">Đang tải dữ liệu</h2>',
                '  </div>',
                '  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>',
                '</div>',
                '<div class="modal-body py-5 text-center text-secondary">Đang tải bản ghi cảnh báo...</div>'
            ].join('');

            function isSimpleLeftClick(event) {
                if (!event) {
                    return true;
                }

                return !event.defaultPrevented
                    && event.button === 0
                    && !event.metaKey
                    && !event.ctrlKey
                    && !event.shiftKey
                    && !event.altKey;
            }

            function setLoadingState() {
                var host = document.getElementById('alertHistoryDetailsHost');
                if (host) {
                    host.innerHTML = loadingMarkup;
                }
            }

            function loadAlertHistoryDetails(url, shouldOpen) {
                var host = document.getElementById('alertHistoryDetailsHost');
                if (!host) {
                    return Promise.resolve();
                }

                if (detailsRequestAbortController && typeof detailsRequestAbortController.abort === 'function') {
                    detailsRequestAbortController.abort();
                }

                detailsRequestAbortController = typeof AbortController === 'function'
                    ? new AbortController()
                    : null;

                var requestVersion = ++detailsRequestVersion;
                setLoadingState();

                return fetch(url, {
                    cache: 'no-store',
                    signal: detailsRequestAbortController ? detailsRequestAbortController.signal : undefined,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Không thể tải chi tiết cảnh báo');
                        }
                        return response.text();
                    })
                    .then(function (html) {
                        if (requestVersion !== detailsRequestVersion) {
                            return;
                        }

                        host.innerHTML = html;

                        if (modal && shouldOpen) {
                            modal.show();
                        }
                    })
                    .catch(function (error) {
                        if (error && error.name === 'AbortError') {
                            return;
                        }

                        throw error;
                    });
            }

            function buildDetailsUrlFromTrigger(trigger) {
                if (!trigger) {
                    return null;
                }

                return '@Url.Action("Details", "AlertHistory")'
                    + '?actorIdentifier=' + encodeURIComponent(trigger.getAttribute('data-actor-identifier') || '')
                    + '&actorIdentifierType=' + encodeURIComponent(trigger.getAttribute('data-actor-identifier-type') || '')
                    + '&action=' + encodeURIComponent(trigger.getAttribute('data-action') || '')
                    + '&alertDate=' + encodeURIComponent(trigger.getAttribute('data-alert-date') || '')
                    + '&partnerId=' + encodeURIComponent(trigger.getAttribute('data-partner-id') || '');
            }

            function initAlertHistoryDetails() {
                if (!modal) {
                    var modalElement = document.getElementById('alertHistoryDetailsModal');
                    if (modalElement && typeof bootstrap !== 'undefined') {
                        modal = new bootstrap.Modal(modalElement);
                    }
                }

                document.addEventListener('click', function (event) {
                    var paginationLink = event.target.closest('[data-alert-history-modal-link]');
                    if (paginationLink) {
                        if (!isSimpleLeftClick(event) || paginationLink.closest('.page-item.disabled')) {
                            return;
                        }

                        var href = paginationLink.getAttribute('href');
                        if (!href || href === '#') {
                            return;
                        }

                        event.preventDefault();
                        loadAlertHistoryDetails(href, false).catch(function (error) {
                            console.error('Error loading alert details pagination:', error);
                            alert('Lỗi: ' + error.message);
                        });
                        return;
                    }

                    var trigger = event.target.closest('.alert-history-detail-trigger');
                    if (trigger) {
                        if (!isSimpleLeftClick(event)) {
                            return;
                        }

                        event.preventDefault();
                        var url = buildDetailsUrlFromTrigger(trigger);
                        if (!url) {
                            return;
                        }

                        loadAlertHistoryDetails(url, true)
                            .catch(function (error) {
                                console.error('Error loading alert details:', error);
                                alert('Lỗi: ' + error.message);
                            });
                    }
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initAlertHistoryDetails);
            } else {
                initAlertHistoryDetails();
            }
        })();
    </script>
}
